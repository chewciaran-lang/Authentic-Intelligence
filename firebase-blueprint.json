{
  "entities": {
    "StorageUnit": {
      "title": "StorageUnit",
      "description": "A physical storage location in the house.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the storage unit (e.g., Kitchen Cupboard)."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this storage unit."
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp of the last update."
        },
        "imageUrl": {
          "type": "string",
          "description": "Base64 encoded image or URL of the storage unit."
        }
      },
      "required": ["name", "ownerId", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["caregiver", "patient"],
          "description": "The role of the user."
        },
        "email": {
          "type": "string",
          "description": "User's email address."
        }
      },
      "required": ["role", "email"]
    },
    "Item": {
      "title": "Item",
      "description": "An object stored inside a storage unit.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the item."
        },
        "storageId": {
          "type": "string",
          "description": "The ID of the storage unit where this item is located."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this item."
        },
        "detectedAt": {
          "type": "number",
          "description": "Timestamp when the item was detected."
        },
        "category": {
          "type": "string",
          "description": "Category of the item (e.g., kitchen, medication, documents)."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the item."
        },
        "lastSeenAt": {
          "type": "number",
          "description": "Timestamp when the item was last seen or opened."
        },
        "isEssential": {
          "type": "boolean",
          "description": "Caregiver tag: Essential item."
        },
        "isFrequentlyLost": {
          "type": "boolean",
          "description": "Caregiver tag: Frequently lost item."
        },
        "isEmergency": {
          "type": "boolean",
          "description": "Caregiver tag: Emergency item."
        },
        "caregiverNotes": {
          "type": "string",
          "description": "Private notes from the caregiver."
        },
        "customLabels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Custom labels added by the caregiver (e.g., fragile, do not move)."
        }
      },
      "required": ["name", "storageId", "ownerId", "detectedAt"]
    }
  },
  "firestore": {
    "/storageUnits/{unitId}": {
      "schema": "StorageUnit",
      "description": "Collection of storage units."
    },
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Collection of items across all storage units."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    }
  }
}
