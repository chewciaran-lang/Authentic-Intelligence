// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: storageUnits
// Document ID: auto-generated
// Fields:
//   - name: string (required) - Name of the storage unit
//   - ownerId: string (required) - UID of the owner
//   - updatedAt: number (required) - Timestamp
//
// Collection: items
// Document ID: auto-generated
// Fields:
//   - name: string (required) - Name of the item
//   - storageId: string (required) - ID of the storage unit
//   - ownerId: string (required) - UID of the owner
//   - detectedAt: number (required) - Timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidStorageUnit(data) {
      return hasRequiredFields(['name', 'ownerId', 'updatedAt']) &&
             hasOnlyAllowedFields(['name', 'ownerId', 'updatedAt', 'imageUrl', 'location']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.ownerId is string &&
             data.updatedAt is number &&
             (!('imageUrl' in data) || data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() < 1048576)) &&
             (!('location' in data) || data.location == null || (data.location is string && data.location.size() <= 100));
    }

    function isCaregiver() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'caregiver';
    }

    function isValidUser(data) {
      return hasRequiredFields(['role', 'email']) &&
             hasOnlyAllowedFields(['role', 'email', 'customCategories']) &&
             data.role in ['caregiver', 'patient'] &&
             data.email is string &&
             (!('customCategories' in data) || (data.customCategories is list && data.customCategories.size() <= 20));
    }

    function isValidItem(data) {
      return hasRequiredFields(['name', 'storageId', 'ownerId', 'detectedAt']) &&
             hasOnlyAllowedFields(['name', 'storageId', 'ownerId', 'detectedAt', 'category', 'description', 'lastSeenAt', 'isEssential', 'isFrequentlyLost', 'isEmergency', 'caregiverNotes', 'customLabels', 'backupLocation', 'helpRequested']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.storageId is string &&
             data.ownerId is string &&
             data.detectedAt is number &&
             (!('category' in data) || data.category == null || (data.category is string && data.category.size() <= 50)) &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 500)) &&
             (!('lastSeenAt' in data) || data.lastSeenAt == null || data.lastSeenAt is number) &&
             (!('isEssential' in data) || data.isEssential is bool) &&
             (!('isFrequentlyLost' in data) || data.isFrequentlyLost is bool) &&
             (!('isEmergency' in data) || data.isEmergency is bool) &&
             (!('caregiverNotes' in data) || data.caregiverNotes == null || (data.caregiverNotes is string && data.caregiverNotes.size() <= 1000)) &&
             (!('backupLocation' in data) || data.backupLocation == null || (data.backupLocation is string && data.backupLocation.size() <= 500)) &&
             (!('helpRequested' in data) || data.helpRequested is bool) &&
             (!('customLabels' in data) || (data.customLabels is list && data.customLabels.size() <= 10));
    }

    function isValidActivity(data) {
      return hasRequiredFields(['ownerId', 'title', 'startTime', 'createdAt']) &&
             hasOnlyAllowedFields(['ownerId', 'title', 'startTime', 'location', 'itemsToBring', 'reminded', 'completed', 'createdAt']) &&
             data.ownerId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.startTime is number &&
             (!('location' in data) || data.location is string && data.location.size() <= 200) &&
             (!('itemsToBring' in data) || data.itemsToBring is list && data.itemsToBring.size() <= 20) &&
             (!('reminded' in data) || data.reminded is bool) &&
             (!('completed' in data) || data.completed is bool) &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /storageUnits/{unitId} {
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && isValidStorageUnit(request.resource.data);
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid && isValidStorageUnit(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /items/{itemId} {
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && isValidItem(request.resource.data);
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid && isValidItem(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && isValidActivity(request.resource.data);
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid && isValidActivity(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
